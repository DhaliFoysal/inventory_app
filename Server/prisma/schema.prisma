generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
  superAdmin
}

enum Status {
  active
  deActive
  pending
}

enum CreateBy {
  email
  phone
}

enum Sold {
  sold
  unsold
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  email     String?  @unique
  password  String
  role      Role     @default(admin)
  status    Status   @default(active)
  companyId String?
  createBy  CreateBy @default(email)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Type {
  electric
  cosmetic
  grocery
  electronics
}

model Company {
  id               String             @id @default(cuid())
  address          String
  name             String
  type             Type               @default(electronics)
  userId           String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  Customers        Customers[]
  Account          Accounts[]
  ProductsCategory ProductsCategory[]
}

model Customers {
  id        String     @id @default(cuid())
  name      String
  phone     String     @unique
  email     String?    @unique
  address   String
  isTrader  Boolean    @default(false)
  balance   Int?
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments  Payments[]
  sales     Sales[]
}

model ProductsCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Measurement_Unit {
  id        String   @id @default(cuid())
  type      String
  symbol    String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tax {
  id        String     @id @default(cuid())
  percent   String
  title     String
  companyId String
  products  Products[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Products {
  id                String             @id @default(cuid())
  name              String
  barcode           String
  taxId             String?
  buyingPrice       Float
  sellingPrice      Float
  isWarranty        Boolean            @default(true)
  warrantyType      String?
  warranty          Int?
  isActive          Boolean            @default(true)
  wholesalePrice    Float?
  companyId         String
  buyingTaxId       String?
  isSerialItems     Boolean            @default(false)
  measurementUnitId String
  measurementUnit   String
  img               String?
  tax               Tax?               @relation(fields: [taxId], references: [id])
  Category_Details  Category_Details[]
  Inventories       Inventories[]
  Serial_numbers    SerialNumbers[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  saleItems         SaleItems[]
}

model Category_Details {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  name       String?
  product    Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Inventories {
  id            String    @id @default(cuid())
  quantity      Int
  productId     String
  warehouseName String
  warehouseId   String
  companyId     String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  product       Products  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SerialNumbers {
  id           String     @id @default(cuid())
  serialNumber String
  status       Sold       @default(unsold)
  companyId    String
  productId    String?
  warehouseId  String
  salesId      String?
  Products     Products?  @relation(fields: [productId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  saleItems    SaleItems? @relation(fields: [saleItemsId], references: [id])
  saleItemsId  String?
}

model Warehouse {
  id          String        @id @default(cuid())
  name        String
  address     String
  companyId   String
  Inventories Inventories[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Accounts {
  id            String     @id @default(uuid())
  accountNumber String     @unique
  name          String
  type          String
  balance       Float
  link          String
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments      Payments[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Payments {
  id          String     @id @default(uuid())
  paymentSlip String
  customerId  String
  salesId     String
  amount      Float
  method      String
  status      String
  companyId   String
  sales       Sales      @relation(fields: [salesId], references: [id])
  customer    Customers  @relation(fields: [customerId], references: [id])
  accounts    Accounts[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Sales {
  id              String      @id @default(uuid())
  invoiceNo       String      @unique
  customerId      String
  subTotal        Float
  totalAmount     Float
  dueAmount       Float
  salesPersonName String
  discount        Float       @default(0)
  discountPercent Float       @default(0)
  payments        Payments[]
  saleItems       SaleItems[]
  customer        Customers   @relation(fields: [customerId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SaleItems {
  id           String          @id @default(uuid())
  productName  String
  salesId      String
  productId    String
  quantity     Float
  unitPrice    Float
  taxPercent   Float           @default(0)
  taxAmount    Float           @default(0)
  totalPrice   Float
  serialNumber SerialNumbers[]
  sales        Sales           @relation(fields: [salesId], references: [id])
  product      Products        @relation(fields: [productId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}
